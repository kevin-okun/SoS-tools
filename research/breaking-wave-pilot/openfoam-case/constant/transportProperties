FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (water air);

water
{
    transportModel  Newtonian;
    nu              1e-06;
    rho             1000;
}

air
{
    transportModel  Newtonian;
    // 100x physical air viscosity: suppresses the spurious shared-velocity air
    // jet that forms along the interface and wind-ripples the shallow surface.
    // Water is untouched; air dynamics are irrelevant to this clip.
    nu              1.48e-03;
    rho             1;
}

sigma           0.07;


